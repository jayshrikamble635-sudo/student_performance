import streamlit as st
import pandas as pd

st.title("Student Performance App")

# File uploader (no Google Drive)
uploaded_file = st.file_uploader("Upload your CSV file", type=["csv"])

if uploaded_file is not None:
    data = pd.read_csv(uploaded_file)
    
    st.subheader("Dataset Preview")
    st.write(data.head())

    st.subheader("Basic Info")
    st.write(data.describe())

# Manual input for prediction
st.subheader("Enter Student Details")

hours = st.number_input("Hours Studied", min_value=0.0, max_value=24.0)
attendance = st.slider("Attendance (%)", 0, 100)
sleep = st.number_input("Sleep Hours", min_value=0.0, max_value=12.0)

def predict_performance(hours, attendance, sleep):
    score = (hours * 10) + (attendance * 0.5) + (sleep * 5)
    return score

if st.button("Predict"):
    result = predict_performance(hours, attendance, sleep)
    st.success(f"Predicted Score: {round(result, 2)}")
